generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MEMBER
  REVIEWER
  ADMIN
}

enum SongStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum SuggestionType {
  NEW_SONG
  EDIT_EXISTING
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  password      String
  role          Role         @default(MEMBER)
  songs         Song[]
  suggestions   Suggestion[] @relation("suggestedBy")
  reviews       Suggestion[] @relation("reviewedBy")
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Song {
  id              String       @id @default(cuid())
  title           String
  originalTitle   String?
  author          String
  originalAuthor  String?
  lyrics          String
  originalLyrics  String?
  observation     String?
  tone            String?
  hymnNumber      String?
  bibleReference  String?
  status          SongStatus   @default(PUBLISHED)
  categories      SongCategory[]
  videos          SongVideo[]
  suggestions     Suggestion[]
  createdBy       String
  createdByUser   User         @relation(fields: [createdBy], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Category {
  id    String        @id @default(cuid())
  name  String        @unique
  songs SongCategory[]
}

model SongCategory {
  songId     String
  categoryId String
  song       Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([songId, categoryId])
}

model SongVideo {
  id        String   @id @default(cuid())
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  url       String
  label     String?
  createdAt DateTime @default(now())
}

model Suggestion {
  id            String           @id @default(cuid())
  type          SuggestionType   @default(NEW_SONG)
  songId        String?
  song          Song?            @relation(fields: [songId], references: [id])
  title         String
  author        String
  lyrics        String
  tone          String?
  bibleReference String?
  note          String?
  status        SuggestionStatus @default(PENDING)
  suggestedBy   String
  suggester     User             @relation("suggestedBy", fields: [suggestedBy], references: [id])
  reviewedBy    String?
  reviewer      User?            @relation("reviewedBy", fields: [reviewedBy], references: [id])
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Account {
  userId            String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}
