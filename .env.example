# ── Database ──────────────────────────────────────────────
# Local (Docker):
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/letrasipb"

# Produção (Neon):
DATABASE_URL="postgresql://user:password@host:port/db?sslmode=require"

# ── Autenticação (NextAuth v5) ───────────────────────────
# Gerar com: openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST="1"
